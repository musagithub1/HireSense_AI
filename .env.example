# HireSense AI - Environment Configuration
# =========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys
# 3. Save the file and restart the application
#
# The app will automatically load these values from the .env file.

# =========================================
# REQUIRED: OpenRouter API Key
# =========================================
# Get your API key at: https://openrouter.ai/
# This is required for the AI interviewer to work.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =========================================
# OPTIONAL: LangSmith Configuration
# =========================================
# Get your API key at: https://smith.langchain.com/
# This is optional - enables tracing and monitoring.
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=HireSense_AI
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =========================================
# Notes:
# =========================================
# - Emotion detection runs client-side in browser (no API needed)
# - TTS uses browser's built-in Web Speech API (no API needed)
# - Voice input uses browser's Speech Recognition API (no API needed)
